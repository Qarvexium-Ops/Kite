# Testing Standard Library
# Unit testing framework

let test_results = {
    passed: 0,
    failed: 0,
    tests: []
}

# Assert functions
fn assert_equal(actual, expected, message) {
    if actual == expected {
        test_results["passed"] = test_results["passed"] + 1
        print("[PASS]", message)
        return true
    } else {
        test_results["failed"] = test_results["failed"] + 1
        print("[FAIL]", message)
        print("  Expected:", expected)
        print("  Actual:", actual)
        return false
    }
}

fn assert_not_equal(actual, expected, message) {
    if actual != expected {
        test_results["passed"] = test_results["passed"] + 1
        print("[PASS]", message)
        return true
    } else {
        test_results["failed"] = test_results["failed"] + 1
        print("[FAIL]", message)
        return false
    }
}

fn assert_true(value, message) {
    return assert_equal(value, true, message)
}

fn assert_false(value, message) {
    return assert_equal(value, false, message)
}

fn assert_null(value, message) {
    return assert_equal(value, null, message)
}

fn assert_not_null(value, message) {
    return assert_not_equal(value, null, message)
}

fn assert_greater(actual, expected, message) {
    if actual > expected {
        test_results["passed"] = test_results["passed"] + 1
        print("[PASS]", message)
        return true
    } else {
        test_results["failed"] = test_results["failed"] + 1
        print("[FAIL]", message)
        return false
    }
}

fn assert_less(actual, expected, message) {
    if actual < expected {
        test_results["passed"] = test_results["passed"] + 1
        print("[PASS]", message)
        return true
    } else {
        test_results["failed"] = test_results["failed"] + 1
        print("[FAIL]", message)
        return false
    }
}

# Test suite
fn test_suite(name, tests) {
    print("\\n=== Test Suite:", name, "===")
    
    for test in tests {
        test()
    }
    
    print("\\n=== Results ===")
    print("Passed:", test_results["passed"])
    print("Failed:", test_results["failed"])
    print("Total:", test_results["passed"] + test_results["failed"])
    
    return test_results
}

# Benchmark
fn benchmark(name, func, iterations) {
    print("Benchmarking:", name)
    
    let start = now()
    for i in range(iterations) {
        func()
    }
    let end = now()
    
    let duration = end - start
    let per_iteration = duration / iterations
    
    print("  Total time:", duration, "ms")
    print("  Per iteration:", per_iteration, "ms")
    print("  Iterations:", iterations)
    
    return {
        duration: duration,
        per_iteration: per_iteration,
        iterations: iterations
    }
}
